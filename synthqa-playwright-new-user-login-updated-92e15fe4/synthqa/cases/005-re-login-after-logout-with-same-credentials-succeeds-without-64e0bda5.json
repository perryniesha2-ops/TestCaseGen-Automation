{
  "id": "64e0bda5-ecdd-429d-b9eb-c30480aa8cb0",
  "title": "Re-Login After Logout With Same Credentials Succeeds Without Requiring Page Reload",
  "description": "Verifies idempotency of the login flow: a user who logs out and immediately logs back in with the same credentials in the same browser tab (without a page reload) is fully re-authenticated. This catches bugs where logout leaves stale form state, disabled inputs, or cached auth tokens that interfere with a fresh login attempt.",
  "test_type": "functional",
  "expected_result": "PASS: The second login in the same tab succeeds, user reaches /dashboard, user identity is correct. The form was properly reset after logout — inputs were enabled and empty. FAIL: Submit button is disabled after logout, form retains previous email/password, second login returns an error despite valid credentials, or the user is redirected to an unexpected page.",
  "test_steps": [
    {
      "step_number": 1,
      "action": "Navigate to the login page",
      "expected": "Login page is displayed",
      "selector": "body",
      "action_type": "navigate",
      "input_value": "/login",
      "assertion": {
        "type": "url",
        "value": "/login"
      }
    },
    {
      "step_number": 2,
      "action": "Fill email for first login attempt",
      "expected": "Email field populated",
      "selector": "input[name='email']",
      "action_type": "fill",
      "input_value": "florence.okafor@meridian.org",
      "assertion": {
        "type": "value",
        "value": "florence.okafor@meridian.org",
        "target": "input[name='email']"
      }
    },
    {
      "step_number": 3,
      "action": "Fill password for first login attempt",
      "expected": "Password field populated",
      "selector": "input[type='password']",
      "action_type": "fill",
      "input_value": "Junip3r!Lakes77",
      "assertion": {
        "type": "value",
        "value": "Junip3r!Lakes77",
        "target": "input[type='password']"
      }
    },
    {
      "step_number": 4,
      "action": "Submit first login",
      "expected": "User lands on /dashboard",
      "selector": "[data-testid='submit-button']",
      "action_type": "click",
      "assertion": {
        "type": "url",
        "value": "/dashboard"
      }
    },
    {
      "step_number": 5,
      "action": "Wait for authenticated content to load",
      "expected": "Dashboard content visible",
      "selector": "[data-testid='user-menu']",
      "action_type": "wait",
      "wait_time": 3000,
      "assertion": {
        "type": "visible",
        "target": "[data-testid='user-menu']"
      }
    },
    {
      "step_number": 6,
      "action": "Open user menu",
      "expected": "Logout option is visible in the dropdown",
      "selector": "[data-testid='user-menu']",
      "action_type": "click",
      "assertion": {
        "type": "visible",
        "target": "[data-testid='logout-button']"
      }
    },
    {
      "step_number": 7,
      "action": "Click Logout to end the session",
      "expected": "User is returned to /login",
      "selector": "[data-testid='logout-button']",
      "action_type": "click",
      "assertion": {
        "type": "url",
        "value": "/login"
      }
    },
    {
      "step_number": 8,
      "action": "Confirm the login email input is present and enabled (form reset properly)",
      "expected": "Email input is visible and enabled, not disabled or pre-filled",
      "selector": "input[name='email']",
      "action_type": "wait",
      "wait_time": 2000,
      "assertion": {
        "type": "enabled",
        "target": "input[name='email']"
      }
    },
    {
      "step_number": 9,
      "action": "Confirm email field is empty (no stale value from previous session)",
      "expected": "Email input is empty",
      "selector": "input[name='email']",
      "action_type": "wait",
      "wait_time": 500,
      "assertion": {
        "type": "value",
        "value": "",
        "target": "input[name='email']"
      }
    },
    {
      "step_number": 10,
      "action": "Fill email for second login attempt in the same tab",
      "expected": "Email field accepts input normally",
      "selector": "input[name='email']",
      "action_type": "fill",
      "input_value": "florence.okafor@meridian.org",
      "assertion": {
        "type": "value",
        "value": "florence.okafor@meridian.org",
        "target": "input[name='email']"
      }
    },
    {
      "step_number": 11,
      "action": "Fill password for second login attempt",
      "expected": "Password field populated",
      "selector": "input[type='password']",
      "action_type": "fill",
      "input_value": "Junip3r!Lakes77",
      "assertion": {
        "type": "value",
        "value": "Junip3r!Lakes77",
        "target": "input[type='password']"
      }
    },
    {
      "step_number": 12,
      "action": "Submit the second login",
      "expected": "User is authenticated again and redirected to /dashboard",
      "selector": "[data-testid='submit-button']",
      "action_type": "click",
      "assertion": {
        "type": "url",
        "value": "/dashboard"
      }
    },
    {
      "step_number": 13,
      "action": "Confirm authenticated user identity is correct on second login",
      "expected": "User menu is visible confirming successful re-authentication",
      "selector": "[data-testid='user-menu']",
      "action_type": "wait",
      "wait_time": 3000,
      "assertion": {
        "type": "visible",
        "target": "[data-testid='user-menu']"
      }
    }
  ]
}