{
  "id": "c46a7f41-faed-4a90-9fb9-622e3ec7d89a",
  "title": "Generate Test Cases Using a Custom Template and Verify Structured Output Format",
  "description": "Verifies that a user can select a custom template (e.g., BDD/Gherkin) and generate test cases that conform to that template's structure.",
  "test_type": "functional",
  "expected_result": "The system generates test cases in BDD Gherkin format including Given/When/Then scenarios derived from the 'Password Reset Workflow' requirement. The output matches the selected custom template structure.",
  "test_steps": [
    {
      "step_number": 1,
      "action": "Navigate to the test case generator page",
      "expected": "Test case generator page is displayed",
      "selector": "body",
      "action_type": "navigate",
      "input_value": "/generate",
      "assertion": {
        "type": "url",
        "value": "/generate"
      }
    },
    {
      "step_number": 2,
      "action": "Select the requirement 'Password Reset Workflow'",
      "expected": "Requirement 'Password Reset Workflow' is selected",
      "selector": "[data-testid='requirement-password-reset-workflow']",
      "action_type": "click",
      "assertion": {
        "type": "attribute",
        "value": "true",
        "target": "[data-testid='requirement-password-reset-workflow']",
        "attribute": "aria-selected"
      }
    },
    {
      "step_number": 3,
      "action": "Select the 'BDD Gherkin' custom template",
      "expected": "Template 'BDD Gherkin' is selected",
      "selector": "[data-testid='template-bdd-gherkin']",
      "action_type": "click",
      "assertion": {
        "type": "attribute",
        "value": "true",
        "target": "[data-testid='template-bdd-gherkin']",
        "attribute": "aria-selected"
      }
    },
    {
      "step_number": 4,
      "action": "Click the Generate Test Cases button",
      "expected": "Generation starts and loading state is shown",
      "selector": "[data-testid='generate-test-cases-button']",
      "action_type": "click",
      "assertion": {
        "type": "visible",
        "target": "[data-testid='loading-spinner']"
      }
    },
    {
      "step_number": 5,
      "action": "Wait for results to load",
      "expected": "Results panel becomes visible",
      "selector": "[data-testid='results-panel']",
      "action_type": "wait",
      "assertion": {
        "type": "visible",
        "target": "[data-testid='results-panel']"
      }
    },
    {
      "step_number": 6,
      "action": "Verify the test cases include Gherkin-style Given/When/Then keywords",
      "expected": "Generated test cases contain Gherkin structured steps",
      "selector": "[data-testid='generated-test-cases']",
      "action_type": "hover",
      "assertion": {
        "type": "text",
        "value": "Given",
        "target": "[data-testid='generated-test-cases']"
      }
    }
  ]
}