{
  "id": "884ce9c9-d449-4a43-b929-e8b6fe393ed5",
  "title": "Export Generated Test Cases to CSV Format Successfully",
  "description": "Verifies that after generating test cases, the user can export them to CSV format and that the downloaded file contains all generated test cases.",
  "test_type": "functional",
  "expected_result": "A CSV file is downloaded containing all generated test cases for 'Shopping Cart Checkout'. An 'Export successful' confirmation message appears in the UI. No data is missing or malformed.",
  "test_steps": [
    {
      "step_number": 1,
      "action": "Navigate to the test case generator page with pre-generated results",
      "expected": "Test case generator page is loaded",
      "selector": "body",
      "action_type": "navigate",
      "input_value": "/generate",
      "assertion": {
        "type": "url",
        "value": "/generate"
      }
    },
    {
      "step_number": 2,
      "action": "Select requirement 'Shopping Cart Checkout'",
      "expected": "Requirement is selected",
      "selector": "[data-testid='requirement-shopping-cart-checkout']",
      "action_type": "click",
      "assertion": {
        "type": "checked",
        "target": "[data-testid='requirement-shopping-cart-checkout']"
      }
    },
    {
      "step_number": 3,
      "action": "Select the Default Template",
      "expected": "Default Template is selected",
      "selector": "[data-testid='template-default']",
      "action_type": "click",
      "assertion": {
        "type": "checked",
        "target": "[data-testid='template-default']"
      }
    },
    {
      "step_number": 4,
      "action": "Click Generate Test Cases",
      "expected": "Generation starts",
      "selector": "[data-testid='generate-button']",
      "action_type": "click",
      "assertion": {
        "type": "visible",
        "target": "[data-testid='generation-progress']"
      }
    },
    {
      "step_number": 5,
      "action": "Wait for test cases to appear in the results panel",
      "expected": "Test cases are displayed",
      "selector": "[data-testid='test-cases-results']",
      "action_type": "wait",
      "assertion": {
        "type": "visible",
        "target": "[data-testid='test-cases-results']"
      }
    },
    {
      "step_number": 6,
      "action": "Click the Export to CSV button",
      "expected": "CSV file download is triggered",
      "selector": "[data-testid='export-csv-button']",
      "action_type": "click",
      "assertion": {
        "type": "visible",
        "target": "[data-testid='download-progress']"
      }
    },
    {
      "step_number": 7,
      "action": "Verify the export success message is displayed",
      "expected": "Success message confirms CSV export completed",
      "selector": "[data-testid='export-success-message']",
      "action_type": "wait",
      "assertion": {
        "type": "visible",
        "target": "[data-testid='export-success-message']"
      }
    }
  ]
}